---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSlider from "../components/HeroSlider.astro";
import { pages } from "../content/pages";
import conditions from "../data/conditions/index";

const toParagraphs = (text = "") =>
  text
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean);
---
<BaseLayout title="Best Florence Chiropractor | Florence, SC" description="Chiropractic care in Florence, SC.">
<Header />
<main class="container">
  <HeroSlider />

  <section class="section">
    <div class="card">
      <h2>{pages.home.welcomeTitle}</h2>
      {toParagraphs(pages.home.welcomeBody).map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="card">
      <h2>Who We Are</h2>
      {toParagraphs(pages.home.whoWeAre).map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="card">
      <h2>Mission Statement</h2>
      {toParagraphs(pages.home.missionStatement).map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="card">
      <h2>Vision Statement</h2>
      {toParagraphs(pages.home.visionStatement).map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="section conditions-preview">
    <h2>Conditions We Treat</h2>
    <p>
      Our clinic works with patients experiencing a wide range of
      musculoskeletal and neurological conditions.
    </p>

    <div class="conditions-grid">
      {conditions.map((condition) => (
        <a href={`/conditions/${condition.slug}`} class="condition-card">
          <h3>{condition.title}</h3>
          <p>{condition.heroTagline}</p>
        </a>
      ))}
    </div>

    <a class="view-all-conditions" href="/conditions">
      View All Conditions &rarr;
    </a>
  </section>
</main>
<Footer />
</BaseLayout>

<style>
  .conditions-preview {
    max-width: 1100px;
    margin: 0 auto 26px;
  }

  .conditions-preview h2 {
    margin-bottom: 8px;
  }

  .conditions-preview > p {
    margin: 0 0 18px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 820px;
  }

  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 14px;
  }

  .condition-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #ffffff;
    padding: 18px;
    text-decoration: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .condition-card:hover {
    border-color: var(--accent-purple);
    box-shadow: 0 8px 24px rgba(107, 95, 211, 0.12);
    transform: translateY(-2px);
  }

  .condition-card h3 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 1.08rem;
  }

  .condition-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.58;
    font-size: 0.95rem;
  }

  .view-all-conditions {
    display: inline-block;
    color: var(--accent-purple);
    font-weight: 600;
  }

  @media (max-width: 1000px) {
    .conditions-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .conditions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
