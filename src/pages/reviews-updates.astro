---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import data from "../data/google-reviews.json";

const reviews = Array.isArray(data.reviews) ? data.reviews.slice(0, 5) : [];
const hasReviews = reviews.length > 0;
const overallRating = typeof data.rating === "number" ? data.rating : 0;
const totalReviews = typeof data.totalReviews === "number" ? data.totalReviews : 0;

const renderStars = (value = 0) => {
  const count = Math.max(0, Math.min(5, Math.round(value)));
  return "\u2605\u2605\u2605\u2605\u2605".slice(0, count);
};
---
<BaseLayout title="Reviews & Updates | Best Florence Chiropractor" description="Reviews & Updates page.">
  <Header />
  <main class="container">
    <section class="section">
      <h1>Google Reviews</h1>

      <div class="card">
        <h2>{data.name}</h2>
        <p>{renderStars(overallRating)}</p>
        <p class="muted">Overall Rating: {overallRating.toFixed(1)}</p>
        <p class="muted">Total Reviews: {totalReviews}</p>
        <a class="btn btn-primary" href={data.googleUrl} target="_blank" rel="noopener noreferrer">
          Read All Reviews on Google
        </a>
      </div>

      {hasReviews ? (
        reviews.map((review) => (
          <div class="card">
            <h2>{review.author}</h2>
            <p>{renderStars(review.rating)}</p>
            <p class="muted">{review.relativeTime}</p>
            <p>{review.text}</p>
          </div>
        ))
      ) : (
        <div class="card">
          <p class="muted">Google reviews will appear here soon.</p>
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
